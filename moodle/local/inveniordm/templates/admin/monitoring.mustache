<div class="container monitoring-container">

    <div class="page-hero">
        <div class="page-hero-content">
            <h1>
                <i class="fa fa-heartbeat"></i>
                System Monitoring
            </h1>

            <p>
                Monitor Moodle services and InvenioRDM integration status.
            </p>
        </div>

        <div class="hero-actions">
            <a href="{{backurl}}" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left"></i>
                Back
            </a>
        </div>
    </div>

    <div class="dashboard-card mt-4">

        <div class="card-header">
            <i class="fa fa-heartbeat"></i>
            System Health
        </div>

        <div class="card-body text-center">

            <div class="health-score {{health.badgeclass}}">
                {{health.score}}%
            </div>

            <div class="progress mt-3">
                <div
                    class="progress-bar bg-{{health.badgeclass}}"
                    style="width: {{health.score}}%;">
                </div>
            </div>

            <div class="mt-3">
                Overall system health evaluation
            </div>

        </div>

    </div>

    <div class="row g-4 mt-4">

        <div class="col-lg-6">

            <div class="dashboard-card h-100">

                <div class="card-header">
                    <i class="fa fa-database"></i>
                    Database Status
                </div>

                <div class="card-body">

                    <span class="status-badge {{database.badgeclass}}">
                        {{database.badgetext}}
                    </span>

                    <table class="table-enhanced mt-3">

                        <tbody>

                            <tr>
                                <td>Status</td>
                                <td>{{database.message}}</td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <div class="col-lg-6">

            <div class="dashboard-card h-100">

                <div class="card-header">
                    <i class="fa fa-cloud"></i>
                    InvenioRDM API
                </div>

                <div class="card-body">

                    <span class="status-badge {{api.badgeclass}}">
                        {{api.badgetext}}
                    </span>

                    <table class="table-enhanced mt-3">

                        <tbody>

                            <tr>
                                <td>HTTP Code</td>
                                <td>{{api.httpcode}}</td>
                            </tr>

                            <tr>
                                <td>Latency</td>
                                <td>{{api.latency}} ms</td>
                            </tr>

                            <tr>
                                <td>Message</td>
                                <td>{{api.message}}</td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

    <div class="dashboard-card mt-4">

        <div class="card-header">
            <i class="fa fa-server"></i>
            System Information
        </div>

        <div class="card-body">

            <table class="table-enhanced">

                <tbody>

                    <tr>
                        <td>Moodle Version</td>
                        <td>{{systeminfo.moodleversion}}</td>
                    </tr>

                    <tr>
                        <td>PHP Version</td>
                        <td>{{systeminfo.phpversion}}</td>
                    </tr>

                    <tr>
                        <td>Operating System</td>
                        <td>{{systeminfo.serveros}}</td>
                    </tr>

                    <tr>
                        <td>Memory Limit</td>
                        <td>{{systeminfo.memorylimit}}</td>
                    </tr>

                    <tr>
                        <td>Timezone</td>
                        <td>{{systeminfo.timezone}}</td>
                    </tr>

                    <tr>
                        <td>Server Time</td>
                        <td>{{systeminfo.servertime}}</td>
                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>