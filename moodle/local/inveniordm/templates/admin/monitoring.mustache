<div class="container monitoring-container">
    <div class="page-hero">
        <div class="page-hero-content">
            <h1>
                <i class="fa fa-heartbeat"></i>
                System Monitoring
            </h1>
            <p>Monitor Moodle services and InvenioRDM integration status.</p>
        </div>

        <div class="hero-actions">
            <a href="{{backurl}}" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left"></i>
                Back
            </a>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-lg-4">
            <div class="dashboard-card h-100">
                <div class="card-header">
                    <i class="fa fa-database"></i>
                    Database Status
                </div>
                <div class="card-body">
                    <div class="alert alert-{{dbclass}} mb-0">
                        <strong>{{dbtext}}</strong>
                        <hr>
                        {{database.message}}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="dashboard-card h-100">
                <div class="card-header">
                    <i class="fa fa-cloud"></i>
                    InvenioRDM API
                </div>

                <div class="card-body">
                    <div class="alert alert-{{apiclass}} mb-0">
                        <strong>{{apitext}}</strong>
                        <hr>
                        <p>
                            <strong>HTTP Code:</strong>
                            {{api.httpcode}}
                        </p>
                        <p>
                            <strong>Latency:</strong>
                            {{api.latency}} ms
                        </p>
                        <p class="mb-0">
                            <strong>Message:</strong>
                            {{api.message}}
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="dashboard-card h-100">
                <div class="card-header">
                    <i class="fa fa-heartbeat"></i>
                    Health Score
                </div>
                <div class="card-body">
                    <div class="alert alert-{{healthclass}} mb-3">
                        <h2 class="mb-0">
                            {{healthscore}} / 100
                        </h2>
                    </div>
                    <div class="progress">
                        <div
                            class="progress-bar bg-{{healthclass}}"
                            role="progressbar"
                            style="width: {{healthscore}}%;"
                            aria-valuenow="{{healthscore}}"
                            aria-valuemin="0"
                            aria-valuemax="100">
                        </div>
                    </div>
                    <p class="mt-3 mb-0">
                        Overall system health based on database connectivity,
                        API availability and response time.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>