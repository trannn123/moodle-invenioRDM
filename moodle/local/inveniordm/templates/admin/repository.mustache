<div class="container repository-container">
    <div class="page-hero">
        <div class="page-hero-content">
            <h1>
                <i class="fa fa-folder-open"></i>
                Repository Management
            </h1>

            <p>
                Browse and manage all learning resources stored in InvenioRDM.
            </p>
        </div>

        <div class="hero-actions">
            <a href="{{backurl}}" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left"></i>
                Back
            </a>
        </div>
    </div>

    <div class="repository-card mt-4">
            <form method="get" class="search-form">
                <div class="search-input-group">
                    <input type="text" name="search" value="{{search}}" class="form-control" placeholder="Search resources...">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-search"></i>
                        Search
                    </button>

                    <a href="{{backurl}}" class="btn btn-outline-secondary">
                        <i class="fa fa-rotate-left"></i>
                        Reset
                    </a>
                </div>
            </form>
    </div>

    <div class="mt-3 mb-3">
        <strong>
            Total Resources:
            {{totalresources}}
        </strong>
    </div>

    <div class="repository-card">
        <div class="repository-card-header">
            <i class="fa fa-folder-open"></i>
            Repository Resources
        </div>

        <div class="repository-card-body">
            {{#hasresources}}
            <div class="repository-table-wrapper">
                <table class="repository-table">
                    <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Files</th>
                        <th>Date</th>
                        <th class="text-center">Action</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#resources}}

                    <tr>
                        <td>
                            {{title}}
                        </td>
                        <td>
                            <span class="repository-status">
                                {{status}}
                            </span>
                        </td>
                        <td>
                            {{filecount}}
                        </td>
                        <td>
                            {{date}}
                        </td>
                        <td class="text-center">
                            <a href="{{viewurl}}" class="btn btn-sm btn-primary">
                                <i class="fa fa-eye"></i>
                                View
                            </a>
                        </td>
                    </tr>
                    {{/resources}}
                    </tbody>
                </table>
            </div>
            {{> local_inveniordm/resource/pagination}}
            {{/hasresources}}

            {{^hasresources}}
            <div class="repository-empty-state alert-info mb-0">
                No resources found.
            </div>
            {{/hasresources}}
        </div>
    </div>
</div>