<div class="invenio-dashboard">
    <div class="hero-section">
        <h1>InvenioRDM Learning Repository</h1>
        <p>
            Digital Learning Resource Management System integrated
            between Moodle and InvenioRDM.
        </p>
    </div>

    {{#is_student}}
    <div class="row g-4">
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="card-icon">
                    📝
                </div>
                <h3>
                    Assignments
                </h3>
                <p>
                    View and submit course assignments.
                </p>
                <a class="btn btn-success"
                   href="{{wwwroot}}/local/inveniordm/student/mycourses.php">
                    Open Assignments
                </a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="card-icon">
                    📚
                </div>
                <h3>My Courses</h3>
                <p>
                    Access learning resources attached to your enrolled courses.
                </p>
                <a class="btn btn-primary"
                   href="{{wwwroot}}/local/inveniordm/student/mycourses.php">
                    Open Courses
                </a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="card-icon">
                    🔍
                </div>
                <h3>Repository Search</h3>
                <p>
                    Search learning resources stored in InvenioRDM.
                </p>
                <a class="btn btn-outline-primary"
                   href="{{wwwroot}}/local/inveniordm/student/search.php">
                    Search Repository
                </a>
            </div>
        </div>
    </div>
    {{/is_student}}

    {{#is_lecturer}}
    <div class="row g-4">
        {{#cancreatecourse}}
        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon">➕</div>
                <h3>Create Course</h3>
                <p>Create a new Moodle course.</p>
                <a class="btn btn-warning"
                   href="{{wwwroot}}/course/edit.php">
                    Create
                </a>
            </div>
        </div>
        {{/cancreatecourse}}
        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon">📚</div>
                <h3>Courses</h3>
                <p>Manage course resources.</p>
                <a class="btn btn-primary"
                   href="{{wwwroot}}/local/inveniordm/lecturer/mycourses.php">
                    Open
                </a>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">

                <div class="card-icon">
                    📝
                </div>

                <h3>
                    Assignments
                </h3>

                <p>
                    Manage assignments and submissions.
                </p>

                <a class="btn btn-dark"
                   href="{{wwwroot}}/local/inveniordm/lecturer/mycourses.php">
                    Manage
                </a>

            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon">⬆️</div>
                <h3>Upload</h3>
                <p>Publish learning resources.</p>
                <a class="btn btn-success"
                   href="{{wwwroot}}/local/inveniordm/lecturer/upload.php">
                    Upload
                </a>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon">📄</div>
                <h3>Resources</h3>
                <p>Browse repository resources.</p>
                <a class="btn btn-info"
                   href="{{wwwroot}}/local/inveniordm/lecturer/myresources.php">
                    Open
                </a>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon">🔍</div>
                <h3>Search</h3>
                <p>Find and attach resources.</p>
                <a class="btn btn-secondary"
                   href="{{wwwroot}}/local/inveniordm/student/search.php">
                    Search
                </a>
            </div>
        </div>
    </div>
    {{/is_lecturer}}
</div>