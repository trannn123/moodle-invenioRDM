<div class="invenio-dashboard">
    <div class="hero-section">
        <h1>Learning Resource Management System</h1>
        <p>
            A digital repository integrated with Moodle and InvenioRDM for managing,
            sharing, and accessing learning resources across courses.
        </p>
    </div>

    {{#is_student}}
    <div class="row g-4">
        <div class="col-md-6 mb-4">
                    <div class="dashboard-card">
                        <div class="card-icon"><i class="fa fa-book"></i></div>
                        <h3>Browse Courses</h3>
                        <p>Explore all available courses and view their learning materials.</p>
                        <a class="btn btn-primary" href="{{wwwroot}}/local/inveniordm/student/all_courses.php">Browse Courses</a>
                    </div>
                </div>
        <div class="col-md-6 mb-4">
            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-tasks"></i></div>
                <h3>Assignments</h3>
                <p>View assignment details, track deadlines, and submit your work.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/local/inveniordm/student/all_assignments.php">View Assignments</a>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-graduation-cap"></i></div>
                <h3>My Courses</h3>
                <p>Access courses you are enrolled in and their attached resources.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/local/inveniordm/student/my_courses.php">Open My Courses</a>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-search"></i></div>
                <h3>Search Repository</h3>
                <p>Search learning resources stored in InvenioRDM.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/local/inveniordm/resource/search.php">Search Resources</a>
            </div>
        </div>
    </div>
    {{/is_student}}

    {{#is_lecturer}}
    <div class="row g-4">
        {{#cancreatecourse}}
        <div class="col-md-6 mb-4 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-plus-circle"></i></div>
                <h3>Create Course</h3>
                <p>Create a new Moodle course and prepare learning activities.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/course/edit.php">Create Course</a>
            </div>
        </div>
        {{/cancreatecourse}}
        <div class="col-md-6 mb-4 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-book"></i></div>
                <h3>My Courses</h3>
                <p>Manage your courses, resources, and learning activities.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/local/inveniordm/lecturer/my_courses.php">Manage Courses</a>
            </div>
        </div>
        <div class="col-md-6 mb-4 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-upload"></i></div>
                <h3>Upload Resource</h3>
                <p>Upload learning materials and publish them to InvenioRDM.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/local/inveniordm/lecturer/upload.php">Upload Resource</a>
            </div>
        </div>
        <div class="col-md-6 mb-4 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-folder-open"></i></div>
                <h3>My Resources</h3>
                <p>View, update, and manage resources you have published.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/local/inveniordm/lecturer/my_resources.php">Manage Resources</a>
            </div>
        </div>
        <div class="col-md-6 mb-4 col-xl-3">
            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-search"></i></div>
                <h3>Search Repository</h3>
                <p>Search and view learning resources stored in the InvenioRDM repository.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/local/inveniordm/resource/search.php">Search Resources</a>
            </div>
        </div>
    </div>
    {{/is_lecturer}}

    {{#is_admin}}
        <div class="admin-dashboard">
            {{^is_admin}}
            <div class="hero-section">
                <h1>Learning Resource Management System</h1>
                <p>
                    A digital repository integrated with Moodle and InvenioRDM for managing,
                    sharing, and accessing learning resources across courses.
                </p>
            </div>
            {{/is_admin}}

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fa fa-folder-open"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-number">{{resourcecount}}</div>
                        <div class="stat-label">Resources</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fa fa-book"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-number">{{coursecount}}</div>
                        <div class="stat-label">Courses</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fa fa-tasks"></i>
                    </div>
                    <div class="stat-content">
