                        <div class="stat-label">Submissions</div>
                    </div>
                </div>
            </div>
            <div class="row g-4 mt-2">
                <div class="col-lg-6">
                    <div class="admin-module-card">
                        <div class="module-header">
                            <i class="fa fa-cogs"></i>
                            <h3>System Management</h3>
                        </div>
                        <p class="module-description">
                            Configure repository integration and manage cache settings.
                        </p>
                        <div class="module-actions">
                            <a href="#" class="module-link">
                                <i class="fa fa-sliders"></i>
                                Repository Settings
                            </a>
                            <a href="{{wwwroot}}/local/inveniordm/admin/cache.php" class="module-link">
                                <i class="fa fa-database"></i>
                                Cache Management
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="admin-module-card">
                        <div class="module-header">
                            <i class="fa fa-chart-line"></i>
                            <h3>Monitoring & Analytics</h3>
                        </div>
                        <p class="module-description">
                            Monitor system health and review repository activity.
                        </p>
                        <div class="module-actions">
                            <a href="{{wwwroot}}/local/inveniordm/admin/analytics.php" class="module-link">
                                <i class="fa fa-chart-bar"></i>
                                Analytics Dashboard
                            </a>
                            <a href="{{wwwroot}}/local/inveniordm/admin/monitoring.php" class="module-link">
                                <i class="fa fa-heartbeat"></i>
                                System Monitoring
                            </a>
                            <a href="{{wwwroot}}/local/inveniordm/admin/reports.php" class="module-link">
                                <i class="fa fa-file-alt"></i>
                                Activity Reports
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="repository-management">
                <div class="repository-header">
                    <i class="fa fa-folder-open"></i>
                    <h3>Repository Management</h3>
                </div>
                <p>
                    Access repository entities and review learning resource relationships.
                </p>
                <div class="repo-grid">
                    <a href="{{wwwroot}}/local/inveniordm/resource/search.php" class="repo-card">
                        <i class="fa fa-file"></i>
                        <span>Resources</span>
                    </a>
                    <a href="#" class="repo-card">
                        <i class="fa fa-book"></i>
                        <span>Courses</span>
                    </a>
                    <a href="#" class="repo-card">
                        <i class="fa fa-tasks"></i>
                        <span>Assignments</span>
                    </a>
                    <a href="#" class="repo-card">
                        <i class="fa fa-users"></i>
                        <span>User Activity</span>
                    </a>
                </div>
            </div>
        </div>
        {{/is_admin}}
</div>