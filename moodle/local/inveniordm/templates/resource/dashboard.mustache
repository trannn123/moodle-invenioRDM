            <div class="dashboard-card">
                <div class="card-icon"><i class="fa fa-plus-circle"></i></div>
                <h3>Create Course</h3>
                <p>Create a new Moodle course and prepare learning activities.</p>
                <a class="btn btn-primary" href="{{wwwroot}}/course/edit.php">Create Course</a>
            </div>
        </div>
        {{/cancreatecourse}}
        <div class="col-md-6 mb-4 col-xl-3">
