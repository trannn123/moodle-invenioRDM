<div class="search-page">
<div class="page-hero">
    <div class="page-hero-content">
        <h1>Academic Repository Portal</h1>
        <p>
            Search research papers, books, theses and learning resources
        </p>
    </div>
    <div class="hero-actions">
        <a href="{{backurl}}" class="btn btn-outline-secondary">
            <i class="fa fa-arrow-left"></i>
            Back
        </a>
    </div>
</div>

<div class="search-card mb-4">
    <form method="get">
        <div class="input-group invenio-search-box">
            <input type="text" name="q" value="{{query}}" class="form-control form-control-lg" placeholder="Search resources...">
            <button type="submit" class="btn btn-primary btn-lg">Search</button>
        </div>

        <div class="row mt-3 invenio-filter-section">
            <div class="col-md-6">
                <select name="format" class="form-select">
                    <option value="">All Formats</option>
                    <option value="pdf">PDF</option>
                    <option value="doc">DOC</option>
                    <option value="docx">DOCX</option>
                    <option value="ppt">PPT</option>
                    <option value="pptx">PPTX</option>
                    <option value="xls">XLS</option>
                    <option value="xlsx">XLSX</option>
                </select>
            </div>

            <div class="col-md-6">
                <select name="level" class="form-select">
                    <option value="">All Educational Levels</option>
                    <option value="school education">School Education</option>
                    <option value="higher education">Higher Education</option>
                    <option value="bachelor's degree">Bachelor Degree</option>
                    <option value="master's degree">Master Degree</option>
                    <option value="doctorate">Doctorate</option>
                </select>
            </div>
        </div>
    </form>
</div>
<h4 class="mb-4">Search Results</h4>
{{#records}}

<div class="card invenio-card mb-4">
    <div class="card-body">
        <h3 class="invenio-title mb-3">{{title}}</h3>
        <div class="row">
            <div class="col-md-8">
                <div class="mb-2">
                    <strong>Author:</strong>
                    {{author}}
                </div>

                <div class="mb-2">
                    <strong>Discipline:</strong>
                    {{discipline}}
                </div>

                <div class="mb-2">
                    <strong>Educational Level:</strong>
                    {{educationallevel}}
                </div>
            </div>

            <div class="col-md-4 text-md-end">
                <span class="bg-secondary text-white fw-bolder text-center"
                    style="
                        display:inline-block;
                        width:90px;
                        padding:4px 8px;
                        border-radius:4px;
                    "
                >
                    {{format}}
                </span>
            </div>
        </div>

        <hr>

        <a href="{{viewurl}}" class="btn btn-outline-primary">View Details</a>
    </div>
</div>
{{/records}}

{{^records}}
<div class="alert alert-secondary">
    No records found.
</div>
{{/records}}

</div>
